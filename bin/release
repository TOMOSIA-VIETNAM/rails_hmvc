#!/usr/bin/env bash
set -euo pipefail

# ─────────────────────────────────────────────
# Usage:
#   bin/release <version>                    # full release (build + push)
#   bin/release <version> --prepare          # test, bump, tag, build — stop before push
#   bin/release <version> --deploy           # push pre-built gem + git push tags
#   bin/release <version> -k <api_key_name>  # push with named credential
#
# API key resolution (first match wins, skipped with --prepare):
#   1. GEM_HOST_API_KEY from .env
#   2. -k flag (named key from ~/.gem/credentials)
# ─────────────────────────────────────────────

VERSION="${1:?Usage: bin/release <version> [--prepare|--deploy] [-k <api_key_name>]}"
API_KEY_NAME=""
MODE="full"

shift
while [[ $# -gt 0 ]]; do
  case "$1" in
    --prepare) MODE="prepare"; shift ;;
    --deploy)  MODE="deploy"; shift ;;
    -k) API_KEY_NAME="${2:?-k requires a key name}"; shift 2 ;;
    *)  echo "Unknown option: $1"; exit 1 ;;
  esac
done

VERSION_FILE="lib/rails_hmvc/version.rb"
CHANGELOG="CHANGELOG.md"
GEMSPEC="rails_hmvc.gemspec"
GEM_FILE="rails_hmvc-$VERSION.gem"

# ── Helpers ────────────────────────────────────
divider() { echo ""; echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"; }
step()     { echo ""; echo "▶ [$1] $2"; }
ok()       { echo "  ✔ $1"; }
fail()     { echo "  ✘ $1"; exit 1; }

# ── Validate version format ────────────────────
if [[ ! "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
  fail "Version must be semver format (x.y.z)"
fi

# ── Load .env ─────────────────────────────────
if [[ -f .env ]]; then
  set -a
  source .env
  set +a
fi

# ═══════════════════════════════════════════════
# Deploy mode — push pre-built gem + git push
# ═══════════════════════════════════════════════
if [[ "$MODE" == "deploy" ]]; then
  if [[ ! -f "$GEM_FILE" ]]; then
    fail "$GEM_FILE not found. Run bin/release $VERSION --prepare first."
  fi

  divider
  echo "  rails_hmvc deploy"
  echo "  Version : $VERSION"
  echo "  Gem     : $GEM_FILE"
  divider

  echo ""
  read -r -p "Enter RubyGems OTP: " OTP
  [[ -z "$OTP" ]] && fail "OTP is required"

  step "1/2" "Pushing gem to RubyGems"
  if [[ -n "$API_KEY_NAME" ]]; then
    gem push "$GEM_FILE" --otp "$OTP" -k "$API_KEY_NAME"
  elif [[ -n "${GEM_HOST_API_KEY:-}" ]]; then
    gem push "$GEM_FILE" --otp "$OTP"
  else
    gem push "$GEM_FILE" --otp "$OTP"
  fi
  ok "Pushed to RubyGems"
  rm -f "$GEM_FILE"

  step "2/3" "Pushing commits and tags to remote"
  GIT_ROOT="$(git rev-parse --show-toplevel)"
  REMOTE_FILE="$GIT_ROOT/.cursor/remote"
  if [[ -f "$REMOTE_FILE" ]]; then
    REMOTE_URL=$(tr -d '[:space:]' < "$REMOTE_FILE")
    ok "Detected .cursor/remote — using temp remote ($REMOTE_URL)"
    git remote add _temp_deploy "$REMOTE_URL" 2>/dev/null || true
    git push _temp_deploy main --tags
    git remote remove _temp_deploy 2>/dev/null
  else
    git push origin main --tags
  fi
  ok "Pushed to GitHub"

  step "3/3" "Creating GitHub Release"
  GH_REPO=""
  if [[ -f "$REMOTE_FILE" ]]; then
    GH_REPO=$(tr -d '[:space:]' < "$REMOTE_FILE" | sed -E 's|.*github\.com[:/]||;s|\.git$||')
  fi

  RELEASE_NOTES=$(awk -v ver="$VERSION" '
    $0 ~ "^## \\[" ver "\\]" {found=1; next}
    found && /^## \[/ {exit}
    found {print}
  ' "$CHANGELOG")

  if command -v gh >/dev/null 2>&1; then
    GH_ARGS=(--title "v$VERSION")
    [[ -n "$GH_REPO" ]] && GH_ARGS+=(--repo "$GH_REPO")

    if [[ -z "$(echo "$RELEASE_NOTES" | tr -d '[:space:]')" ]]; then
      gh release create "v$VERSION" "${GH_ARGS[@]}" --generate-notes
    else
      echo "$RELEASE_NOTES" | gh release create "v$VERSION" "${GH_ARGS[@]}" --notes-file -
    fi
    ok "GitHub Release v$VERSION created"
  else
    echo "  gh CLI not found — skip GitHub Release (create manually)"
  fi

  divider
  echo ""
  echo "  Released v$VERSION successfully!"
  divider
  exit 0
fi

# ═══════════════════════════════════════════════
# Prepare / Full mode — test, bump, tag, build
# ═══════════════════════════════════════════════

# ── Resolve API key (skip when --prepare) ────
if [[ "$MODE" == "prepare" ]]; then
  AUTH_METHOD="none"
  AUTH_DISPLAY="(skipped — prepare only)"
elif [[ -n "${GEM_HOST_API_KEY:-}" ]]; then
  AUTH_METHOD="env"
  AUTH_DISPLAY="${GEM_HOST_API_KEY:0:12}..."
elif [[ -n "$API_KEY_NAME" ]]; then
  AUTH_METHOD="credentials"
  AUTH_DISPLAY="$API_KEY_NAME (from ~/.gem/credentials)"
else
  fail "No API key found. Set GEM_HOST_API_KEY in .env, use -k <key_name>, or use --prepare"
fi

CURRENT=$(grep -oE 'VERSION = "[^"]+"' "$VERSION_FILE" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')

divider
echo "  rails_hmvc release"
echo "  Current version : $CURRENT"
echo "  New version     : $VERSION"
echo "  Mode            : $MODE"
echo "  API key         : $AUTH_DISPLAY"
divider

# ── Guard: clean working tree ──────────────────
if [[ -n "$(git status --porcelain)" ]]; then
  fail "Working directory is not clean. Commit or stash changes first."
fi

# ── Ensure bundle is consistent ───────────────
bundle check >/dev/null 2>&1 || bundle install --quiet

# ── Step 1: Run test suite ─────────────────────
step "1/6" "Running RSpec (with coverage)"
if ! CI=true bundle exec rspec --format progress 2>&1; then
  fail "RSpec failed — aborting release"
fi
ok "RSpec passed"

# ── Step 2: Run RuboCop ───────────────────────
step "2/6" "Running RuboCop"
if ! bundle exec rubocop lib spec Rakefile rails_hmvc.gemspec 2>&1; then
  fail "RuboCop failed — aborting release"
fi
ok "RuboCop passed"

# ── Step 3: Print packaged files ───────────────
step "3/6" "Files to be packaged"
PACKAGED_FILES=$(ruby -e "
spec = Gem::Specification.load('$GEMSPEC')
puts spec.files
")
echo "$PACKAGED_FILES" | sed 's/^/  /'
FILE_COUNT=$(echo "$PACKAGED_FILES" | wc -l | tr -d ' ')
ok "$FILE_COUNT files will be included"

# ── Step 4: Print release notes ───────────────
step "4/6" "Release notes for v$VERSION"
NOTES=$(awk -v ver="$VERSION" '
  $0 ~ "^## \\[" ver "\\]" {found=1; next}
  found && /^## \[/ {exit}
  found {print}
' "$CHANGELOG")
if [[ -z "$(echo "$NOTES" | tr -d '[:space:]')" ]]; then
  echo "  (No entries for v$VERSION in CHANGELOG)"
else
  echo "$NOTES" | sed 's/^/  /'
fi

# ── Confirm ────────────────────────────────────
divider
echo ""
read -r -p "Proceed with release v$VERSION? [y/N] " CONFIRM
case "$CONFIRM" in
  [yY]) ;;
  *) echo "Aborted."; exit 0 ;;
esac

# ── Step 5: Bump version + commit + tag ────────
step "5/6" "Bumping version, committing, tagging"

sed -i.bak "s/VERSION = \"$CURRENT\"/VERSION = \"$VERSION\"/" "$VERSION_FILE"
rm -f "${VERSION_FILE}.bak"
ok "Updated $VERSION_FILE → $VERSION"

bundle install --quiet
git add "$VERSION_FILE" Gemfile.lock
if git diff --cached --quiet; then
  ok "No changes to commit (version already at $VERSION)"
else
  git commit -m "chore: release v$VERSION"
fi

if git rev-parse "v$VERSION" >/dev/null 2>&1; then
  git tag -d "v$VERSION"
  ok "Removed existing tag v$VERSION"
fi
git tag -a "v$VERSION" -m "Release v$VERSION"
ok "Committed + tagged v$VERSION"

# ── Step 6: Build gem ─────────────────────────
step "6/6" "Building gem"
rm -f "$GEM_FILE"
gem build "$GEMSPEC"
ok "Built $GEM_FILE"

if [[ "$MODE" == "prepare" ]]; then
  divider
  echo ""
  echo "  Prepared v$VERSION — gem built, ready to deploy."
  echo ""
  echo "  Next:"
  echo "    bin/release $VERSION --deploy"
  divider
  exit 0
fi

# ── Full mode: push gem ──────────────────────
if [[ "$AUTH_METHOD" == "env" ]]; then
  gem push "$GEM_FILE"
else
  gem push "$GEM_FILE" -k "$API_KEY_NAME"
fi
ok "Pushed to RubyGems"

rm -f "$GEM_FILE"

# ── Done ───────────────────────────────────────
divider
echo ""
echo "  Released v$VERSION successfully!"
echo ""
echo "  Next: push commits, tags, and create GitHub Release"
echo "    bin/release $VERSION --deploy"
echo "  (or manually: git push origin main --tags && gh release create v$VERSION)"
divider
