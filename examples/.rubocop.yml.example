# Rails HMVC RuboCop Configuration Example
# Copy this file to your project root as .rubocop.yml

require:
  - rails_hmvc  # This loads all Rails HMVC cops

plugins:
  - rubocop-rails
  - rubocop-rspec

AllCops:
  TargetRubyVersion: 3.2  # Adjust to your project's Ruby version (3.0, 3.1, 3.2, etc.)
  NewCops: enable
  Exclude:
    - 'vendor/**/*'
    - 'bin/**/*'
    - 'db/**/*'
    - 'node_modules/**/*'
    - 'tmp/**/*'
    - 'log/**/*'
    - 'spec/fixtures/**/*'

# ============================================================================
# STYLE RULES
# ============================================================================

Style/Documentation:
  Enabled: false  # Disable for HMVC components that are self-documenting

Style/StringLiterals:
  EnforcedStyle: single_quotes

Style/StringLiteralsInInterpolation:
  EnforcedStyle: double_quotes

Style/FrozenStringLiteralComment:
  Enabled: true

Style/ClassAndModuleChildren:
  EnforcedStyle: compact
  Exclude:
    - 'app/controllers/**/*'   # Allow nested modules for namespacing
    - 'app/operations/**/*'
    - 'app/forms/**/*'
    - 'app/serializers/**/*'

Style/MethodCallWithArgsParentheses:
  Enabled: true
  EnforcedStyle: require_parentheses
  Exclude:
    - 'Gemfile'
    - 'Rakefile'
    - '*.gemspec'

# ============================================================================
# LAYOUT RULES
# ============================================================================

Layout/LineLength:
  Max: 120  # Reasonable for modern screens

# ============================================================================
# METRICS RULES - HMVC Optimized
# ============================================================================

Metrics/MethodLength:
  Max: 20
  Exclude:
    - 'lib/generators/**/*'
    - 'app/operations/**/step_*.rb'  # Step methods can be longer for business logic

Metrics/ClassLength:
  Max: 300
  Exclude:
    - 'lib/generators/**/*'
    - 'app/operations/**/*'  # Operations can be longer due to multiple step methods

Metrics/BlockLength:
  Exclude:
    - 'spec/**/*'          # RSpec blocks can be long
    - 'lib/generators/**/*' # Generator templates can be long
    - 'config/routes.rb'   # Routes file can be long

Metrics/AbcSize:
  Max: 20
  Exclude:
    - 'app/operations/**/step_*.rb'  # Step methods contain concentrated business logic

# ============================================================================
# NAMING CONVENTIONS - HMVC Specific
# ============================================================================

Naming/MethodName:
  EnforcedStyle: snake_case
  Include:
    - 'app/operations/**/*.rb'
  AllowedPatterns:
    - '^step_'  # Allow step_ prefix for operation step methods

# ============================================================================
# RAILS SPECIFIC RULES
# ============================================================================

Rails/ActionFilter:
  EnforcedStyle: action
  Include:
    - 'app/controllers/**/*.rb'

# ============================================================================
# RSPEC RULES
# ============================================================================

RSpec/DescribedClass:
  Enabled: true

RSpec/ExampleLength:
  Max: 10

RSpec/MultipleExpectations:
  Max: 5

RSpec/NestedGroups:
  Max: 3

# ============================================================================
# RAILS HMVC CUSTOM COPS
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# OPERATIONS COPS
# ─────────────────────────────────────────────────────────────────────────────

RailsHmvc/Operations/CallMethod:
  Description: 'Operation classes must have a call method'
  Enabled: true
  Include:
    - 'app/operations/**/*_operation.rb'

RailsHmvc/Operations/StepMethods:
  Description: 'Operation call method should delegate to step methods'
  Enabled: true
  Include:
    - 'app/operations/**/*_operation.rb'

RailsHmvc/Operations/BusinessLogicOnly:
  Description: 'Operations should not contain direct model calls in call method'
  Enabled: true
  Include:
    - 'app/operations/**/*_operation.rb'

# ─────────────────────────────────────────────────────────────────────────────
# FORMS COPS
# ─────────────────────────────────────────────────────────────────────────────

RailsHmvc/Forms/ValidationOnly:
  Description: 'Form classes should only contain validation logic'
  Enabled: true
  Include:
    - 'app/forms/**/*_form.rb'

RailsHmvc/Forms/NoDatabaseInteraction:
  Description: 'Form classes should not interact with database'
  Enabled: true
  Include:
    - 'app/forms/**/*_form.rb'

# ─────────────────────────────────────────────────────────────────────────────
# CONTROLLERS COPS
# ─────────────────────────────────────────────────────────────────────────────

RailsHmvc/Controllers/NoBusinessLogic:
  Description: 'Controllers should not contain business logic'
  Enabled: true
  Include:
    - 'app/controllers/**/*_controller.rb'

RailsHmvc/Controllers/DelegateToOperations:
  Description: 'Controller actions should delegate to Operations'
  Enabled: true
  Include:
    - 'app/controllers/**/*_controller.rb'

# ─────────────────────────────────────────────────────────────────────────────
# MODELS COPS
# ─────────────────────────────────────────────────────────────────────────────

RailsHmvc/Models/ConcernsLocation:
  Description: 'Complex model methods should be extracted to concerns'
  Enabled: true
  Include:
    - 'app/models/*.rb'
  Exclude:
    - 'app/models/concerns/**/*'

# ============================================================================
# PROJECT SPECIFIC CUSTOMIZATIONS
# ============================================================================
# Uncomment and customize these rules based on your project needs:

# # Disable specific cops for legacy code
# RailsHmvc/Operations/StepMethods:
#   Exclude:
#     - 'app/operations/legacy/**/*'

# # Customize metrics for specific directories
# Metrics/ClassLength:
#   Exclude:
#     - 'app/operations/complex/**/*'

# # Allow specific patterns for your domain
# RailsHmvc/Forms/ValidationOnly:
#   AllowedMethods: ['validates', 'validate', 'attribute', 'custom_method']
